{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "Slot": {
    "type": "object",
    "required": ["slotId","tipo","data","horaInicio","duracao","status"],
    "properties": {
      "slotId": {"type":"string"},
      "tipo": {"enum":["AULA","PESSOAL"]},
      "data": {"type":"string","pattern":"^\\d{4}-\\d{2}-\\d{2}$"},
      "horaInicio": {"type":"string","pattern":"^\\d{2}:\\d{2}$"},
      "duracao": {"type":"integer","minimum":15},
      "endereco": {"type":["string","null"]},
      "descricao": {"type":["string","null"]},
      "status": {"enum":["disponivel","ocupado","bloqueado","alocado"]},
      "alunoAlocado": {"type":["string","null"]},
      "diasFixos": {"type":"array","items":{"type":"integer","minimum":1,"maximum":7}},
      "periodoAlocacaoInicio": {"type":["string","null" ],"pattern":"^\\d{4}-\\d{2}-\\d{2}$"},
      "periodoAlocacaoFim": {"type":["string","null" ],"pattern":"^\\d{4}-\\d{2}-\\d{2}$"},
      "googleEventId": {"type":["string","null"]},
      "sincronizadoDe": {"enum":["APP","CALENDAR"]}
    }
  },
  "Agendamento": {
    "type":"object",
    "required":["agendId","slotId","alunoId","dataAgendamento"],
    "properties":{
      "agendId":{"type":"string"},
      "slotId":{"type":"string"},
      "alunoId":{"type":"string"},
      "nomeAluno":{"type":["string","null"]},
      "emailAluno":{"type":"string","format":"email"},
      "dataAgendamento":{"type":"string","format":"date-time"},
      "googleEventId":{"type":["string","null"]},
      "statusPresenca":{"enum":[null,"Compareceu","Reagendado","Cancelado"]}
    }
  }
}
