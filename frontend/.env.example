# Exemplo de configuração de ambiente
# Copiar este arquivo para .env.local e preencher com os valores corretos

# URL do backend (Apps Script)
VITE_API_URL=https://script.google.com/macros/d/YOUR_SCRIPT_ID/usercontent

# Debug mode
VITE_DEBUG=false

# Timeout de requisições (ms)
VITE_API_TIMEOUT=30000